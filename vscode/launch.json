{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run AppBoost",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["ts-node"],
      "program": "${workspaceFolder}/src/server.ts",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_ENV": "development"
      }
    }
  ]
}